---
import '@/styles/global.css';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  keywords?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  lang?: string;
}

const { title, description = "Coze - Software Development Journey", image, keywords, type = 'website', publishedTime, lang = 'en' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = image ? new URL(image, Astro.site).href : new URL('/images/og-image.png', Astro.site).href;
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="dark light" />
    <meta name="theme-color" content="#212c2a" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" type="application/rss+xml" title="Coze Blog" href={new URL("rss.xml", Astro.site)} />
    <link rel="sitemap" href="/sitemap.xml" />
    <link rel="me" href="https://mastodon.world/@arda" />

    <!-- Fonts: shared brand trio with arda.tr / resume.arda.tr -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Archivo:wght@500;600;700&family=Manrope:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Arda Karaduman" />
    {keywords && <meta name="keywords" content={keywords} />}

    <!-- Fediverse -->
    <meta name="fediverse:creator" content="@arda@mastodon.world" />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content="Coze — blog.arda.tr" />
    <meta property="og:locale" content="en_US" />
    {type === 'article' && publishedTime && (
      <meta property="article:published_time" content={publishedTime} />
    )}
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@ardakaraduman" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Theme boot: runs before paint to avoid a flash. Migrates the legacy
         theme names, otherwise falls back to the visitor's system preference
         (including prefers-contrast → high-contrast themes). -->
    <script is:inline>
      (function () {
        var THEMES = ['blade', 'alucard', 'paper', 'dracula-pro', 'carbon', 'buffy', 'lincoln', 'morbius', 'van-helsing'];
        var LEGACY = { dark: 'blade', light: 'alucard', dracula: 'dracula-pro' };
        var COLORS = {
          blade: '#212c2a', alucard: '#f7f5f0', paper: '#ffffff',
          'dracula-pro': '#22202d', carbon: '#050505', buffy: '#2a202c',
          lincoln: '#2c2a21', morbius: '#2c2021', 'van-helsing': '#090a0c'
        };
        var stored = localStorage.getItem('theme');
        if (stored && LEGACY[stored]) stored = LEGACY[stored];
        var theme = stored;
        if (!theme || THEMES.indexOf(theme) === -1) {
          var hc = matchMedia('(prefers-contrast: more)').matches;
          var light = matchMedia('(prefers-color-scheme: light)').matches;
          theme = hc ? (light ? 'paper' : 'carbon') : (light ? 'alucard' : 'blade');
        }
        document.documentElement.classList.add(theme);
        var meta = document.querySelector('meta[name="theme-color"]');
        if (meta && COLORS[theme]) meta.setAttribute('content', COLORS[theme]);
      })();
    </script>
  </head>
  <body class="min-h-screen bg-background text-foreground">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <!-- Cloudflare Web Analytics (cookieless). is:inline keeps the beacon verbatim
         so Astro doesn't bundle it or drop the data-cf-beacon attribute. -->
    <script is:inline defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "bd17608cad3d493a941bb5738f6f645f"}'></script>
    <!-- End Cloudflare Web Analytics -->
  </body>
</html>

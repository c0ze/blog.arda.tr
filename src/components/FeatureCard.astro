---
import { tagChipClass, formatDate } from '@/lib/display';

interface Props {
  slug: string;
  title: string;
  date: Date;
  excerpt: string;
  tags: string[];
  no: string;
  fresh?: boolean;
}

const { slug, title, date, excerpt, tags, no, fresh = false } = Astro.props;
---

<article class="group relative rounded-xl border border-border bg-card p-7 shadow-soft transition-all duration-300 hover:border-primary/50 hover:shadow-medium sm:p-9">
  {fresh && (
    <span class="absolute -top-3 right-6 rounded bg-glow-yellow px-2 py-1 font-mono text-[0.6rem] font-bold uppercase tracking-[0.14em] text-background">
      fresh ink
    </span>
  )}
  <div class="flex flex-wrap items-baseline gap-x-4 gap-y-1">
    <span class="font-mono text-xs tracking-widest text-primary">{no}</span>
    <time datetime={date.toISOString()} class="font-mono text-xs text-muted-foreground">{formatDate(date)}</time>
  </div>
  <h2 class="mt-3 font-display text-2xl font-bold leading-tight tracking-tight sm:text-3xl">
    <a href={`/blog/${slug}`} class="transition-colors after:absolute after:inset-0 after:content-[''] group-hover:text-primary">
      {title}
    </a>
  </h2>
  {excerpt && <p class="mt-3 max-w-2xl leading-relaxed text-muted-foreground">{excerpt}</p>}
  {tags.length > 0 && (
    <div class="mt-5 flex flex-wrap gap-2">
      {tags.map((tag) => <span class={tagChipClass(tag)}>#{tag}</span>)}
    </div>
  )}
</article>

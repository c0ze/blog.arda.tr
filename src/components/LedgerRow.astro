---
import { tagChipClass, formatDateShort } from '@/lib/display';

interface Props {
  slug: string;
  title: string;
  date: Date;
  tags: string[];
  no: string;
}

const { slug, title, date, tags, no } = Astro.props;
---

<a href={`/blog/${slug}`} class="ledger-row group px-1">
  <span class="ledger-no">{no}</span>
  <time datetime={date.toISOString()} class="font-mono text-xs text-muted-foreground">{formatDateShort(date)}</time>
  <span class="min-w-0">
    <span class="block truncate font-display text-base font-semibold tracking-tight transition-colors group-hover:text-primary sm:text-lg">
      {title}
    </span>
    {tags.length > 0 && (
      <span class="mt-1.5 hidden flex-wrap gap-1.5 sm:flex">
        {tags.slice(0, 4).map((tag) => <span class={tagChipClass(tag)}>#{tag}</span>)}
      </span>
    )}
  </span>
</a>

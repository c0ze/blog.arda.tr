---
import { formatDateShort } from '@/lib/display';
import TagChip from '@/components/TagChip.astro';

interface Props {
  slug: string;
  title: string;
  date: Date;
  tags: string[];
  no: string;
}

const { slug, title, date, tags, no } = Astro.props;
---

<div class="ledger-row group relative px-1">
  <span class="ledger-no">{no}</span>
  <time datetime={date.toISOString()} class="font-mono text-xs text-muted-foreground">{formatDateShort(date)}</time>
  <span class="min-w-0">
    <a
      href={`/blog/${slug}`}
      class="block truncate font-display text-base font-semibold tracking-tight transition-colors after:absolute after:inset-0 after:content-[''] group-hover:text-primary sm:text-lg"
    >
      {title}
    </a>
    {tags.length > 0 && (
      <span class="relative z-[1] mt-1.5 hidden flex-wrap gap-1.5 sm:flex">
        {tags.slice(0, 4).map((tag) => <TagChip tag={tag} />)}
      </span>
    )}
  </span>
</div>

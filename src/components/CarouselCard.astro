---
import TagChip from '@/components/TagChip.astro';
import { formatDate } from '@/lib/display';

interface Props {
  slug: string;
  title: string;
  date: Date;
  excerpt: string;
  tags: string[];
  no: string;
  image?: string;
  fresh?: boolean;
}

const { slug, title, date, excerpt, tags, no, image, fresh = false } = Astro.props;
const ogImage = image || '/images/og-image.png';
---

<article class="group relative flex h-full flex-col overflow-hidden rounded-xl border border-border bg-card shadow-soft transition-all duration-300 hover:border-primary/50 hover:shadow-medium">
  <div class="relative aspect-[1200/630] overflow-hidden border-b border-border">
    <img
      src={ogImage}
      alt={title}
      loading="lazy"
      decoding="async"
      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.04]"
    />
    {fresh && (
      <span class="absolute left-3 top-3 z-[2] rounded bg-glow-yellow px-2 py-1 font-mono text-[0.6rem] font-bold uppercase tracking-[0.14em] text-background">
        fresh ink
      </span>
    )}
  </div>
  <div class="flex flex-1 flex-col p-5">
    <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
      <span class="font-mono text-xs tracking-widest text-primary">{no}</span>
      <time datetime={date.toISOString()} class="font-mono text-xs text-muted-foreground">{formatDate(date)}</time>
    </div>
    <h3 class="mt-2 font-display text-lg font-bold leading-tight tracking-tight sm:text-xl">
      <a href={`/blog/${slug}`} class="transition-colors after:absolute after:inset-0 after:content-[''] group-hover:text-primary">
        {title}
      </a>
    </h3>
    {excerpt && <p class="mt-2 line-clamp-2 text-sm leading-relaxed text-muted-foreground">{excerpt}</p>}
    {tags.length > 0 && (
      <div class="mt-auto flex flex-wrap gap-1.5 pt-4">
        {tags.slice(0, 4).map((tag) => <TagChip tag={tag} />)}
      </div>
    )}
  </div>
</article>

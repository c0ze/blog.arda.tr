---
import BaseLayout from '@/layouts/BaseLayout.astro';
import LedgerRow from '@/components/LedgerRow.astro';
import { getPublishedPosts, getSlug } from '@/lib/posts';
import { ledgerNo } from '@/lib/display';

const sortedPosts = await getPublishedPosts();
const total = sortedPosts.length;
const allTags = [...new Set(sortedPosts.flatMap((post) => post.data.tags))].sort();
---

<BaseLayout title="Blog - Coze" description="All blog posts from Coze - Software Development Journey">
  <section class="container mx-auto max-w-5xl px-4 py-14">
    <header class="mb-10">
      <span class="font-mono text-[0.7rem] uppercase tracking-[0.24em] text-primary">The full ledger</span>
      <h1 class="mt-3 font-display text-4xl font-bold tracking-tight md:text-5xl">
        All entries<span class="text-primary">.</span>
      </h1>
      <p class="mt-3 max-w-2xl text-lg text-muted-foreground">
        {total} posts of software, side quests, and the occasional séance with old hardware.
      </p>
    </header>

    <!-- Tag filter -->
    <div class="mb-8">
      <div class="flex flex-wrap gap-2" id="tag-filters" role="group" aria-label="Filter posts by tag">
        <button
          class="tag-filter active rounded-full bg-primary px-3.5 py-1.5 font-mono text-xs font-semibold text-primary-foreground transition-colors"
          data-tag="all"
          aria-pressed="true"
        >
          All
        </button>
        {allTags.map((tag) => (
          <button
            class="tag-filter rounded-full bg-secondary px-3.5 py-1.5 font-mono text-xs font-medium text-secondary-foreground transition-colors hover:bg-primary hover:text-primary-foreground"
            data-tag={tag}
            aria-pressed="false"
          >
            #{tag}
          </button>
        ))}
      </div>
    </div>

    <!-- Ledger -->
    <div class="border-t border-border" id="posts-list">
      {sortedPosts.map((post, index) => (
        <div class="post-item" data-tags={post.data.tags.join(',')}>
          <LedgerRow
            slug={getSlug(post)}
            title={post.data.title}
            date={post.data.date}
            tags={post.data.tags}
            no={ledgerNo(index, total)}
          />
        </div>
      ))}
    </div>
    <p id="no-results" class="hidden py-12 text-center font-mono text-sm text-muted-foreground">
      № 000 — no entries match that tag.
    </p>
  </section>
</BaseLayout>

<script>
  const tagButtons = document.querySelectorAll<HTMLButtonElement>('.tag-filter');
  const postItems = document.querySelectorAll<HTMLElement>('.post-item');
  const noResults = document.getElementById('no-results');

  function applyFilter(tag: string, updateUrl: boolean) {
    tagButtons.forEach((btn) => {
      const active = btn.getAttribute('data-tag') === tag;
      btn.classList.toggle('active', active);
      btn.classList.toggle('bg-primary', active);
      btn.classList.toggle('text-primary-foreground', active);
      btn.classList.toggle('bg-secondary', !active);
      btn.classList.toggle('text-secondary-foreground', !active);
      btn.setAttribute('aria-pressed', String(active));
    });

    let visible = 0;
    postItems.forEach((item) => {
      const itemTags = item.getAttribute('data-tags')?.split(',') || [];
      const show = tag === 'all' || itemTags.includes(tag);
      item.style.display = show ? 'block' : 'none';
      if (show) visible++;
    });
    noResults?.classList.toggle('hidden', visible > 0);

    if (updateUrl) {
      const url = new URL(window.location.href);
      if (tag === 'all') url.searchParams.delete('tag');
      else url.searchParams.set('tag', tag);
      history.replaceState(null, '', url);
    }
  }

  tagButtons.forEach((button) => {
    button.addEventListener('click', () => {
      const tag = button.getAttribute('data-tag');
      if (tag !== null) applyFilter(tag, true);
    });
  });

  // Deep-link support: a tag chip anywhere links to /blog?tag=dev, landing pre-filtered.
  const requested = new URLSearchParams(window.location.search).get('tag');
  if (requested && [...tagButtons].some((b) => b.getAttribute('data-tag') === requested)) {
    applyFilter(requested, false);
  }
</script>

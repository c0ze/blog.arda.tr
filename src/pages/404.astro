---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="404 - Page Not Found - Coze">
  <section class="container mx-auto max-w-2xl px-4 py-28 text-center">
    <span class="font-mono text-[0.7rem] uppercase tracking-[0.24em] text-muted-foreground">missing entry</span>
    <h1 class="mt-4 font-display text-7xl font-bold tracking-tight text-primary">№ 404</h1>
    <p class="mt-5 text-xl text-muted-foreground">
      This page isn't in the ledger. Either it never existed, or it was
      quietly retired during a side quest.
    </p>
    <div class="mt-9 flex flex-wrap justify-center gap-3">
      <a
        href="/"
        class="rounded-full bg-primary px-6 py-3 text-sm font-semibold text-primary-foreground transition-transform hover:scale-[1.03]"
      >
        Back to the front page
      </a>
      <a
        href="/archive"
        class="glass rounded-full border px-6 py-3 text-sm font-semibold text-foreground transition-colors hover:text-primary"
      >
        Search the archive
      </a>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CarouselCard from '@/components/CarouselCard.astro';
import TagChip from '@/components/TagChip.astro';
import { getPublishedPosts, getSlug } from '@/lib/posts';
import { ledgerNo } from '@/lib/display';

const posts = await getPublishedPosts();
const total = posts.length;
const featured = posts.slice(0, 6);

// Tag marquee: most-used tags, duplicated for a seamless CSS loop.
const tagCounts = posts
  .flatMap((post) => post.data.tags)
  .reduce((acc, tag) => acc.set(tag, (acc.get(tag) ?? 0) + 1), new Map<string, number>());
const marqueeTags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1]).slice(0, 18).map(([tag]) => tag);
---

<BaseLayout
  title="Coze - Software Development Journey"
  description="Arda Karaduman's tech blog: AI tooling, Go, DevOps, home networking, generative music, and other side quests — logged since 2010."
>
  <!-- JSON-LD: Blog + author -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Blog",
    "name": "Coze",
    "url": "https://blog.arda.tr/",
    "description": "Software development journey: AI tooling, Go, DevOps, and side quests.",
    "inLanguage": "en",
    "author": {
      "@type": "Person",
      "name": "Arda Karaduman",
      "url": "https://arda.tr",
      "sameAs": [
        "https://github.com/c0ze",
        "https://mastodon.world/@arda",
        "https://bsky.app/profile/arda-karaduman.bsky.social"
      ]
    }
  })} />

  <!-- Masthead -->
  <section class="relative overflow-hidden">
    <div class="dotgrid absolute inset-0" aria-hidden="true"></div>
    <div class="container relative mx-auto px-4 pb-12 pt-16 sm:pt-24">
      <span class="glass inline-flex items-center gap-3 rounded-full border px-4 py-1.5">
        <span class="font-mono text-[0.66rem] uppercase tracking-[0.24em] text-primary">The ledger of side quests</span>
        <span class="h-3.5 w-px bg-border" aria-hidden="true"></span>
        <span class="font-mono text-[0.66rem] text-muted-foreground">est. 2010 · {total} entries</span>
      </span>
      <h1 class="mt-7 font-display text-6xl font-bold leading-[0.95] tracking-tight sm:text-7xl md:text-8xl">
        Coze<span class="text-primary">.</span>
      </h1>
      <p class="mt-5 max-w-xl text-lg leading-relaxed text-muted-foreground sm:text-xl">
        Software development journey — AI tooling, Go, DevOps, home networking,
        generative music, and whatever refused to stay a small experiment.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/blog" class="rounded-full bg-primary px-6 py-3 text-sm font-semibold text-primary-foreground transition-transform hover:scale-[1.03]">
          Browse all entries
        </a>
        <a href="/archive" class="glass rounded-full border px-6 py-3 text-sm font-semibold text-foreground transition-colors hover:text-primary">
          Archive by year
        </a>
      </div>
    </div>

    <!-- Tag marquee — each tag links to its filtered listing; hover to pause -->
    <div class="mask-fade-x overflow-hidden border-y border-border py-2.5">
      <div class="marquee-track flex gap-2.5 pr-2.5">
        {marqueeTags.map((tag) => <TagChip tag={tag} />)}
        {marqueeTags.map((tag) => <TagChip tag={tag} hidden />)}
      </div>
    </div>
  </section>

  <!-- Latest entries carousel -->
  <section class="container mx-auto px-4 pt-12">
    <div class="flex items-baseline justify-between border-b border-border pb-3">
      <h2 class="font-mono text-[0.7rem] uppercase tracking-[0.24em] text-muted-foreground">Latest entries</h2>
      <a href="/blog" class="font-mono text-[0.7rem] uppercase tracking-[0.14em] text-primary hover:underline">view all →</a>
    </div>

    <div class="relative mt-5">
      <button
        type="button"
        data-carousel-prev
        aria-label="Previous entries"
        class="carousel-arrow absolute left-0 top-[38%] z-10 h-10 w-10 -translate-x-1/2 items-center justify-center rounded-full border border-border bg-card text-2xl leading-none text-foreground shadow-medium transition-colors hover:border-primary hover:text-primary"
      >‹</button>

      <ul id="latest-carousel" class="carousel-track flex snap-x snap-mandatory gap-5 overflow-x-auto scroll-smooth pb-4">
        {featured.map((post, index) => (
          <li class="carousel-item shrink-0 snap-start list-none">
            <CarouselCard
              slug={getSlug(post)}
              title={post.data.title}
              date={post.data.date}
              excerpt={post.data.excerpt}
              tags={post.data.tags}
              no={ledgerNo(index, total)}
              image={post.data.image}
              fresh={index === 0}
            />
          </li>
        ))}
      </ul>

      <button
        type="button"
        data-carousel-next
        aria-label="More entries"
        class="carousel-arrow absolute right-0 top-[38%] z-10 h-10 w-10 translate-x-1/2 items-center justify-center rounded-full border border-border bg-card text-2xl leading-none text-foreground shadow-medium transition-colors hover:border-primary hover:text-primary"
      >›</button>
    </div>
  </section>

  <!-- Colophon strip -->
  <section class="container mx-auto px-4 pt-16">
    <div class="grid gap-6 rounded-xl border border-border bg-card p-7 shadow-soft sm:grid-cols-[auto_1fr] sm:p-9">
      <span class="font-mono text-xs tracking-widest text-primary">№ 000 / ABOUT</span>
      <div>
        <h2 class="font-display text-xl font-bold tracking-tight">What is this place?</h2>
        <p class="mt-2 leading-relaxed text-muted-foreground">
          Practical notes from a systems architect's workbench in Tokyo: real problems, working
          solutions, and the occasional unhinged experiment with AI, retro hardware, or black metal.
          The serious career stuff lives at <a href="https://resume.arda.tr" class="text-primary underline underline-offset-4">resume.arda.tr</a>;
          everything else gets logged here.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .carousel-track { scrollbar-width: none; -ms-overflow-style: none; }
  .carousel-track::-webkit-scrollbar { display: none; }
  /* Latest card is wider (focused); the rest are scrollable peers. */
  .carousel-item { width: clamp(17rem, 80vw, 22rem); }
  .carousel-item:first-child { width: clamp(20rem, 88vw, 30rem); }
  .carousel-arrow { display: none; }
  @media (min-width: 768px) { .carousel-arrow { display: inline-flex; } }
  /* Pause the tag marquee on hover so the tags are easy to click. */
  .marquee-track:hover { animation-play-state: paused; }
</style>

<script is:inline>
  (function () {
    var track = document.getElementById('latest-carousel');
    if (!track) return;
    var step = function () { return Math.max(track.clientWidth * 0.8, 280); };
    var prev = document.querySelector('[data-carousel-prev]');
    var next = document.querySelector('[data-carousel-next]');
    if (prev) prev.addEventListener('click', function () { track.scrollBy({ left: -step(), behavior: 'smooth' }); });
    if (next) next.addEventListener('click', function () { track.scrollBy({ left: step(), behavior: 'smooth' }); });
  })();
</script>
